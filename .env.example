# Copy to `.env` to override defaults — Compose loads it automatically
# (the `node` service declares it `required: false`, so `.env` is optional).
# Everything here is optional: with no .env the app runs with sensible
# defaults and the in-memory database.

# HTTP server port (default 3000)
# PORT=3000

# Largest party the restaurant will seat (default 10)
# TABLE_SIZE=10

# Set these to use DynamoDB instead of the in-memory store.
# DYNAMODB_ENDPOINT points at LocalStack by its Compose service name,
# because the server runs inside the same Compose network.
# DYNAMODB_TABLE=reservations
# DYNAMODB_ENDPOINT=http://localstack:4566
# AWS_REGION=us-east-1
